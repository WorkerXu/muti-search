{
  "name": "muti-search",
  "version": "0.1.0",
  "productName": "muti-search",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"vite --host 127.0.0.1\" \"wait-on dist/main/main.js http://127.0.0.1:5173 && nodemon --watch dist/main --watch dist/preload --ext js,cjs --exec \\\"VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\\\"\"",
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.node.json",
    "pack:mac": "npm run build && electron-builder --mac dir",
    "pack:mac:universal": "npm run build && electron-builder --mac dir --universal",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "build": {
    "appId": "com.coderxu.muti-search",
    "asar": true,
    "directories": {
      "output": "dist-app"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null
    }
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "concurrently": "^9.2.1",
    "electron": "^39.8.10",
    "electron-builder": "^26.15.3",
    "jsdom": "^27.2.0",
    "nodemon": "^3.1.10",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.3"
  }
}
